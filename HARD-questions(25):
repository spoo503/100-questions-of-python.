class Student:
    def __init__(self,name,mark_1,mark_2,mark_3):
        self.name=name
        self.mark_1=mark_1
        self.mark_2=mark_2
        self.mark_3=mark_3
    def Total_marks(self):
        total=self.mark_1+self.mark_2+self.mark_3
        marks={"SUB1":self.mark_1,
                "SUB2":self.mark_2,
                "SUB3":self.mark_3
              }
        print("Student name",self.name)
        print("Marks",marks)
        print("Total Marks",total)
        self.grade(total)
    def grade(self,total):
        if total>=90:
            print("Grade A")
        elif total>=80:
            print("Grade B")
        elif total>70:
            print("Grade C")
        elif total>50:
            print("PASS")
        elif total<50:
            print("FAIL")
