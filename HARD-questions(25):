2.Implement Selection Sort. 
num=[1,25,46,23,5,6,77,8]
for i in range(len(num)):
    mini=i
    for j in range(i+1,len(num)):
        if num[j]<num[mini]:
          mini=j
          num[i],num[mini]=num[mini],num[i]
print(num)

