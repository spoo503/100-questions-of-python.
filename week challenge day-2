Q12

Take marks:

90+ → A
80+ → B
70+ → C
50+ → D
below → Fail
class Student_progress:
    def __init__(self,**kwargs):
        self.m1=kwargs.get('m1')
        self.m2=kwargs.get('m2')
        self.m3=kwargs.get('m3')
    def display(self):
        print("MARKS OF FIRST SUB",self.m1)
        print("MARKS OF SECOND SUB",self.m2)
        print("MARKS OF THIRD  SUB",self.m3)
class Total(Student_progress):
    def __init__(self,**kwargs):
        super().__init__(**kwargs)
    def result(self):
        total=self.m1+self.m2+self.m3
        print("TOtal of all subjects",total)
        avg=(total)/3
        print("Average of all marks",avg)
        if avg>90:
           print("A")
        elif avg>80:
            print("B")
        elif avg>70:
           print("C")
        elif avg>50:
           print("D")
        else:
          print("FAIL")
s1 = Total(m1=95, m2=80, m3=88)
s1.display()
s1.result()
        
        
